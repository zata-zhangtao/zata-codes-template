# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control - it contains secrets!
#
# Configuration Priority (highest to lowest):
# 1. Environment variables
# 2. .env / .env.local files
# 3. config.toml
# 4. Code defaults
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# [DEPRECATED] 以下三项为历史占位，当前后端代码未读取，保留仅为 compose 插值兼容。
# 初始管理员改由下方 AUTH_ADMIN_BOOTSTRAP_* 种子；会话不再使用 JWT，改用 Redis。
API_SECRET_KEY=your-256-bit-secret-key-here
ADMIN_IDENTIFIER=admin
ADMIN_PASSWORD_HASH=$$2b$$12$$...

# =============================================================================
# Redis (会话存储)
# =============================================================================
# 双认证域的会话持久化依赖 Redis（public / admin 按 key 前缀隔离命名空间）。
# 本地可启动 docker-compose.testing.yml 的 redis（带密码）：
#   REDIS_URL=redis://:redis123@localhost:6379/0
# 或指向任意外部 / 无密码本地 Redis：
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Auth (双认证域)
# =============================================================================
# 初始管理员种子（admin 域）：后端启动时按用户名幂等创建；明文密码仅用于首次
# 创建，库中只保存 bcrypt 哈希。两项任一为空则跳过种子。请在 .env.local 覆盖。
AUTH_ADMIN_BOOTSTRAP_USERNAME=admin
AUTH_ADMIN_BOOTSTRAP_PASSWORD=change-me-please

# =============================================================================
# Database Credentials
# =============================================================================
# Complete database URL. Overrides config.toml defaults.
#
# PostgreSQL (recommended for production / team development):
#   Format: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/app
#
# SQLite (local quick-start, no PostgreSQL required):
#   1. Set DATABASE_URL to a local file path, e.g. sqlite:///./dev.db
#   2. Run: DATABASE_URL=sqlite:///./dev.db uv run alembic upgrade head
#   3. Start services: DATABASE_URL=sqlite:///./dev.db just run
#DATABASE_URL=sqlite:///./dev.db

# =============================================================================
# AI Model API Keys
# =============================================================================
# Each provider declared in config.toml's [providers] block reads its key from
# the env var named by that provider's api_key_env field. Add a line below
# for each provider you actually call. Unset providers are fine until first use.

OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# Frontend Settings (OPTIONAL)
# =============================================================================
# Public frontend base URL for backend API calls.
# Optional: docker-compose.yml defaults to http://localhost:8000.
# Only override this if the backend service name or port differs.
API_BASE_URL=http://localhost:8000

# =============================================================================
# Operations Toolkit (zata-ops)
# =============================================================================
# Database backup/restore, S3 diagnostics, VPS provisioning, log inspection
# and the terminal dashboard have moved to the standalone `zata-ops` CLI.
#
# Install once:
#   cd /path/to/zata-ops && uv tool install --force .
#
# Backup/storage settings now belong to `zata-ops`, not the application
# container. Keep those values in the environment used to run `zata-ops`
# (for example `.env.local` or a scheduled job env). zata-ops loads `.env`
# then `.env.local` automatically; see zata-ops/docs/getting-started.md for
# the full key list.
