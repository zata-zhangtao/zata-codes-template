# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control - it contains secrets!
#
# Configuration Priority (highest to lowest):
# 1. Environment variables
# 2. .env / .env.local files
# 3. config.toml
# 4. Code defaults
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
# Application name used for logging and identification
# APP_NAME=app

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# =============================================================================
# Database Credentials (PostgreSQL)
# =============================================================================
# PostgreSQL username
# POSTGRES_USER=postgres

# PostgreSQL password (required for database connection)
# POSTGRES_PASSWORD=your_secure_password_here

# Complete database URL (optional - overrides component settings)
# Format: postgresql+psycopg2://user:password@host:port/database
# DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/chameleon_meta

# =============================================================================
# MinIO Object Storage Credentials
# =============================================================================
# Standard MinIO access key
# MINIO_ACCESS_KEY=minioadmin

# Standard MinIO secret key
# MINIO_SECRET_KEY=minioadmin

# Docker MinIO root user (fallback if MINIO_ACCESS_KEY not set)
# MINIO_ROOT_USER=minioadmin

# Docker MinIO root password (fallback if MINIO_SECRET_KEY not set)
# MINIO_ROOT_PASSWORD=minioadmin

# =============================================================================
# AI Model API Keys
# =============================================================================
# DashScope (Alibaba) API key for Qwen models
# DASHSCOPE_API_KEY=sk-your-dashscope-key

# OpenRouter API key for accessing multiple model providers
# OPENROUTER_API_KEY=sk-your-openrouter-key

# Vector Engine API key
# VECTORENGINE_API_KEY=sk-your-vectorengine-key

# Azhexing API key
# AZHEXING_API_KEY=sk-your-azhexing-key

# Redbox API key
# REDBOX_API_KEY=sk-your-redbox-key

# =============================================================================
# Optional Overrides
# =============================================================================
# Uncomment to override config.toml settings

# Database settings
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=chameleon_meta
# DB_DRIVER=psycopg2
# DB_BACKEND=postgresql

# Chat model settings
# CHAT_MODEL_NAME=qwen-flash
# CHAT_MODEL_PROVIDER=dashscope
# CHAT_MODEL_TEMPERATURE=0.2

# MinIO settings
# MINIO_ENDPOINT=localhost:9000
# MINIO_SECURE=false
# MINIO_BUCKET_RAW_DOCUMENTS=raw-documents

# Qdrant settings
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION_NAME=document_vectors

# Embedding settings
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIM=384
# EMBEDDING_OFFLINE_MODE=true
# EMBEDDING_MODEL_DIR=resources/models

# Chunking settings
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50

# Timeout settings (in seconds)
# TIMEOUT_EMBEDDING_MODEL_LOAD_SECONDS=300
# TIMEOUT_INGESTION_DOCUMENT_SECONDS=600
# TIMEOUT_INGESTION_JOB_SECONDS=7200
# TIMEOUT_MINIO_SECONDS=60
