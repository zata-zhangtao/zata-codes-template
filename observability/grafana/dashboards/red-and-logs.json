        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${loki_datasource}"
          },
          "expr": "{compose_service=\"zata-codes-template-backend\"}",
          "refId": "A"
        }
      ],
      "title": "Backend Logs",
      "type": "logs"
