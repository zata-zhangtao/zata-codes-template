# DwCrawler Environment Configuration Example
# Copy this file to .env and modify the values according to your setup

# ========== DATABASE CONFIGURATION ==========
# Database connection URL
# Format: postgresql://username:password@host:port/database_name
# For local PostgreSQL: postgresql://postgres:your_password@localhost:5432/dwcrawler
DATABASE_URL=postgresql://postgres:zata1598@localhost:5432/dwcrawler

# ========== CRAWLER CONFIGURATION ==========
# Run browser in headless mode (recommended for Docker/CI environments)
HEADLESS=false

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Maximum number of retries for failed requests
MAX_RETRIES=3

# Delay between crawling different vessels (seconds)
CRAWL_DELAY=5

# ========== LOGGING CONFIGURATION ==========
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# ========== PROXY TYPE ==========
PROXY_TYPE=TUNNEL # TUNNEL or CLASH

# ========== CLASH PROXY CONFIGURATION ==========
# Clash proxy settings for bypassing network restrictions during crawling
# Only required if you need to use proxies for accessing shipping websites

# Clash API URL (default port is 9097 for Clash API)
CLASH_API_URL=http://127.0.0.1:9097

# Clash API secret key (set in your Clash configuration)
# Leave empty if no authentication is required
CLASH_API_SECRET=clashapikey123

# Clash proxy group name (must be a 'select' type group)
# This should match one of your proxy groups in Clash
CLASH_PROXY_GROUP=🇺🇸 美国

# Local proxy port that Clash listens on (usually 7897 for HTTP/SOCKS5)
CLASH_PROXY_PORT=7897

# ========== CLASH PROXY USAGE NOTES ==========
# 1. Install and configure Clash proxy client
# 2. Enable the REST API in your Clash configuration:
#    {
#      "external-controller": "127.0.0.1:9097",
#      "secret": "clashapikey123"
#    }
# 3. Create a proxy group with type "select" containing your proxy servers
# 4. The crawler will automatically switch proxies if network issues occur
# 5. Set CLASH_API_SECRET to empty string if authentication is disabled



# ========== TUNNEL PROXY CONFIGURATION ==========
# TUNNEL URL
PROXY_TUNNEL=XXXX

# TUNNEL PROXY_USERNAME
PROXY_USERNAME=XXXX

# TUNNEL PROXY_PASSWORD
PROXY_PASSWORD=XXXX
