# =============================================================================
# Dokploy Deployment Environment Variables
# =============================================================================
# Copy / rename this file and fill in your production secrets.
# In Dokploy: Project -> Service -> "Environment" tab -> paste key=value pairs.
#
# DO NOT commit real values to git.
# =============================================================================

# =============================================================================
# 1. Dokploy / Traefik (REQUIRED)
# =============================================================================
# Public domain that Traefik will route to the frontend service.
# Example: app.example.com
# DOMAIN=

# =============================================================================
# 2. Database (REQUIRED)
# =============================================================================
# Full PostgreSQL connection string. Overrides config.toml defaults.
# Format: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=

# =============================================================================
# 3. AI Model API Keys (fill in the ones your app actually uses)
# =============================================================================
# DashScope (Alibaba Qwen)
# DASHSCOPE_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=

# OpenRouter
# OPENROUTER_API_KEY=

# Vector Engine
# VECTORENGINE_API_KEY=

# =============================================================================
# 4. Authentication (REQUIRED)
# =============================================================================
# JWT signing secret. Generate with:
#   openssl rand -hex 32
API_SECRET_KEY=

# Admin login identifier.
ADMIN_IDENTIFIER=admin

# Bcrypt hashed admin password. Generate with:
#   python -c 'import bcrypt; print(bcrypt.hashpw(b"change-me", bcrypt.gensalt()).decode())'
# Escape each $ as $$ in Dokploy/Compose env files.
ADMIN_PASSWORD_HASH=$$2b$$12$$...

# =============================================================================
# 5. S3-compatible Backup Storage
# =============================================================================
# S3 endpoint URL. Examples:
#   AWS S3:       https://s3.amazonaws.com
#   Backblaze B2: https://s3.us-east-005.backblazeb2.com
#   MinIO:        http://minio:9000
S3_ENDPOINT=

S3_ACCESS_KEY=

S3_SECRET_KEY=

S3_BUCKET=app-backups
S3_PREFIX=app-backups
BACKUP_TIME=18:00
FULL_BACKUP_DAY=6
RETENTION_DAYS=30

# =============================================================================
# 6. Optional Overrides
# =============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
