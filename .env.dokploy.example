# =============================================================================
# Dokploy Deployment Environment Variables
# =============================================================================
# Copy / rename this file and fill in your production secrets.
# In Dokploy: Project -> Service -> "Environment" tab -> paste key=value pairs.
# Docker Compose only auto-loads a file named .env unless the deploy command
# explicitly passes --env-file. Keep this file as a template and copy its values
# into the Dokploy Compose Environment when deploying through the UI.
#
# DO NOT commit real values to git.
# =============================================================================

# =============================================================================
# 1. Dokploy / Traefik (REQUIRED)
# =============================================================================
# Public domain that Traefik will route to the frontend service.
# Example: app.example.com
DOMAIN=

# =============================================================================
# 2. Database (REQUIRED)
# =============================================================================
# Full PostgreSQL connection string. Overrides config.toml defaults.
# Format: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=

# =============================================================================
# 3. AI Model API Keys
# =============================================================================
# config.toml's [providers] block declares which env var each provider reads.
# Add a line for each provider you actually call; unset providers are fine
# until the first request.

OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# 4. Authentication (REQUIRED)
# =============================================================================
# JWT signing secret. Generate with:
#   openssl rand -hex 32
API_SECRET_KEY=

# Admin login identifier.
ADMIN_IDENTIFIER=admin

# Bcrypt hashed admin password. Generate with:
#   python -c 'import bcrypt; print(bcrypt.hashpw(b"change-me", bcrypt.gensalt()).decode())'
# Escape each $ as $$ in Dokploy/Compose env files.
# [DEPRECATED] 当前后端未读取，保留仅为 compose 兼容；初始管理员改用下方 AUTH_*。
ADMIN_PASSWORD_HASH=$$2b$$12$$...

# 初始管理员种子（admin 域）：后端启动时按用户名幂等创建；明文密码仅用于首次创建。
AUTH_ADMIN_BOOTSTRAP_USERNAME=admin
AUTH_ADMIN_BOOTSTRAP_PASSWORD=

# =============================================================================
# 4b. Redis (会话存储, REQUIRED)
# =============================================================================
# 双认证域会话持久化（public / admin 按 key 前缀隔离）。生产指向托管 Redis。
# Format: redis://[:password@]host:port/db
REDIS_URL=

# =============================================================================
# 5. Operations Toolkit (zata-ops)
# =============================================================================
# Backups, S3 diagnostics, VPS provisioning, and log inspection are now the
# job of the standalone `zata-ops` CLI. Schedule `zata-ops db backup` as a
# Dokploy Scheduled Job (or via systemd / cron / GitHub Actions) with the
# matching S3_* environment variables. The application service no longer
# needs to know about backup storage.

# =============================================================================
# 6. Optional Overrides
# =============================================================================
# Public frontend base URL for backend API calls.
# Optional: docker-compose.dokploy.yml defaults to http://zata-codes-template-backend:8000.
# Only override if your backend service name differs from the compose default.
API_BASE_URL=http://zata-codes-template-backend:8000

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
