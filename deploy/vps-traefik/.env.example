# /opt/apps/zata-codes-template/.env
# Deployment metadata. The *_IMAGE lines may be rewritten by the optional
# GitHub Actions deploy workflow on every release. Runtime secrets live in
# app.env and should never be touched by CD.

# Public hostname. DNS must already resolve to this server, and ports 80/443
# must be open.
DOMAIN=app.example.com

# External Docker network used by the host-level Traefik gateway.
TRAEFIK_NETWORK=traefik

# Container images. Replace the host, namespace, and tags for your registry.
# The deploy workflow rewrites these on every release; only the BACKEND_IMAGE
# and FRONTEND_IMAGE placeholders are needed for a manual first-time bring-up.
BACKEND_IMAGE=registry.example.com/your-namespace/zata-codes-template-backend:initial
FRONTEND_IMAGE=registry.example.com/your-namespace/zata-codes-template-frontend:initial

# Backups, S3 diagnostics, and VPS provisioning have moved to the standalone
# `zata-ops` CLI; the template no longer ships a backup service profile or
# image. Install zata-ops once and call it from a systemd timer / cron /
# GitHub Actions schedule. See zata-ops/docs/guides/scheduling.md.
