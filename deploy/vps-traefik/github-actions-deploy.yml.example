name: Deploy VPS Traefik

on:
  push:
    tags:
      - "v*"
  workflow_dispatch:

permissions:
  contents: read
  packages: write

concurrency:
  group: deploy-vps-traefik-${{ github.ref }}
  cancel-in-progress: false

env:
  REGISTRY_HOST: ${{ secrets.REGISTRY_HOST }}
  REGISTRY_NAMESPACE: ${{ secrets.REGISTRY_NAMESPACE }}

jobs:
  build-and-push:
    name: Build and Push Images
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        include:
          - service: backend
            image_name: zata-codes-template-backend
            context: .
            dockerfile: src/backend/Dockerfile
          - service: admin
            image_name: zata-codes-template-admin
            context: ./frontend-admin
            dockerfile: ./frontend-admin/Dockerfile
          - service: public
            image_name: zata-codes-template-public
            context: ./frontend-public
            dockerfile: ./frontend-public/Dockerfile

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY_HOST }}
          username: ${{ secrets.REGISTRY_USERNAME }}
          password: ${{ secrets.REGISTRY_PASSWORD }}

      - name: Build and push ${{ matrix.service }} image
        uses: docker/build-push-action@v6
        with:
          context: ${{ matrix.context }}
          file: ${{ matrix.dockerfile }}
          push: true
          tags: |
            ${{ env.REGISTRY_HOST }}/${{ env.REGISTRY_NAMESPACE }}/${{ matrix.image_name }}:${{ github.sha }}
          cache-from: type=gha,scope=${{ matrix.service }}
          cache-to: type=gha,scope=${{ matrix.service }},mode=max

  deploy-production:
    name: Deploy Production
    runs-on: ubuntu-latest
    needs: build-and-push
    environment:
      name: production
      url: https://${{ vars.PRODUCTION_DOMAIN }}

    steps:
      - name: Prepare SSH
        env:
          SERVER_HOST: ${{ secrets.SERVER_HOST }}
          SERVER_PORT: ${{ secrets.SERVER_PORT }}
          SERVER_SSH_KEY: ${{ secrets.SERVER_SSH_KEY }}
        run: |
          set -euo pipefail
          mkdir -p ~/.ssh
          chmod 700 ~/.ssh
          printf '%s\n' "$SERVER_SSH_KEY" > ~/.ssh/deploy-vps-traefik
          chmod 600 ~/.ssh/deploy-vps-traefik
          ssh-keyscan -p "${SERVER_PORT:-22}" "$SERVER_HOST" >> ~/.ssh/known_hosts

      - name: Update compose images and restart
        env:
          SERVER_HOST: ${{ secrets.SERVER_HOST }}
          SERVER_PORT: ${{ secrets.SERVER_PORT }}
          SERVER_USER: ${{ secrets.SERVER_USER }}
          APP_DIR: ${{ vars.PRODUCTION_APP_DIR }}
          BACKEND_IMAGE: ${{ env.REGISTRY_HOST }}/${{ env.REGISTRY_NAMESPACE }}/zata-codes-template-backend:${{ github.sha }}
          ADMIN_IMAGE: ${{ env.REGISTRY_HOST }}/${{ env.REGISTRY_NAMESPACE }}/zata-codes-template-admin:${{ github.sha }}
          PUBLIC_IMAGE: ${{ env.REGISTRY_HOST }}/${{ env.REGISTRY_NAMESPACE }}/zata-codes-template-public:${{ github.sha }}
        run: |
          set -euo pipefail
          SERVER_PORT="${SERVER_PORT:-22}"
          APP_DIR="${APP_DIR:-/opt/apps/zata-codes-template}"

          ssh -i ~/.ssh/deploy-vps-traefik -p "$SERVER_PORT" \
            "${SERVER_USER}@${SERVER_HOST}" \
            "APP_DIR='$APP_DIR' BACKEND_IMAGE='$BACKEND_IMAGE' ADMIN_IMAGE='$ADMIN_IMAGE' PUBLIC_IMAGE='$PUBLIC_IMAGE' bash -s" <<'REMOTE'
          set -euo pipefail

          cd "$APP_DIR"

          upsert_env_value() {
            key="$1"
            value="$2"
            target_file="$3"
            if grep -q "^${key}=" "$target_file"; then
              sed -i "s#^${key}=.*#${key}=${value}#" "$target_file"
            else
              printf '%s=%s\n' "$key" "$value" >> "$target_file"
            fi
          }

          test -f .env || {
            echo "Missing $APP_DIR/.env. Prepare the deploy directory before running CD (run zata-ops env provision or your own bootstrap script first)."
            exit 1
          }
          test -f app.env || {
            echo "Missing $APP_DIR/app.env. Prepare the deploy directory before running CD."
            exit 1
          }

          upsert_env_value BACKEND_IMAGE "$BACKEND_IMAGE" .env
          upsert_env_value ADMIN_IMAGE "$ADMIN_IMAGE" .env
          upsert_env_value PUBLIC_IMAGE "$PUBLIC_IMAGE" .env

          docker compose pull
          docker compose up -d --remove-orphans
          docker image prune -f
          REMOTE
