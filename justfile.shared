# ───────────────────────────────────────────────────────────────────────────────
# justfile.shared — recipes synced from the upstream template repository.
#
# This file is overwritten by `just sync-template`. Do NOT add project-specific
# recipes here; put them in `justfile`, which imports this file.
# ───────────────────────────────────────────────────────────────────────────────

# Default recipe (runs when you type 'just')
default: _check-completion
    @just --list

# Internal: check if just shell completion is installed
_check-completion:
    #!/usr/bin/env bash
    set -euo pipefail
    # Skip in CI or non-interactive environments
    if [ -n "${CI:-}" ] || [ -z "${TERM:-}" ] || [ "${TERM}" = "dumb" ]; then
        exit 0
    fi

    shell_name="$(basename "${SHELL:-}")"
    completion_installed="false"

    case "$shell_name" in
        zsh)
            [ -f "$HOME/.zsh/completions/_just" ] && completion_installed="true"
            ;;
        bash)
            [ -f "$HOME/.config/just/just_completion.bash" ] && completion_installed="true"
            ;;
    esac

    if [ "$completion_installed" = "false" ]; then
        echo ""
        printf '\033[1;33m+------------------------------------------------------------+\033[0m\n'
        printf '\033[1;33m|  WARNING: Just shell completion is NOT installed           |\033[0m\n'
        printf '\033[1;33m+------------------------------------------------------------+\033[0m\n'
        printf '\033[1;33m|  Tab-completion for just commands is not available.        |\033[0m\n'
        printf '\033[1;33m|  Run the following command to install it:                  |\033[0m\n'
        printf '\033[1;33m|                                                            |\033[0m\n'
        printf '\033[1;32m|       just sync all                                        |\033[0m\n'
        printf '\033[1;33m|                                                            |\033[0m\n'
        printf '\033[1;33m+------------------------------------------------------------+\033[0m\n'
        echo ""
    fi

# NOTE:
#   Run `just sync all` once on a local machine to install shell completion
#   for `just` in the current shell profile.

# Sync dependencies
# Usage:
#   just sync           # dev deps (default)
#   just sync prod      # production only, no dev
#   just sync all       # all extras + install just shell completion
#   just sync dev       # all extras + pre-commit hooks
sync mode="": _check-completion
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{mode}}" in
        prod)
            uv sync --no-dev
            ;;
        all)
            uv sync --all-extras
            if [ -z "${CI:-}" ]; then
                shell_name="$(basename "${SHELL:-}")"
                case "$shell_name" in
                    zsh)
                        completion_dir="$HOME/.zsh/completions"
                        completion_dst="$completion_dir/_just"
                        mkdir -p "$completion_dir"
                        just --completions zsh > "$completion_dst"
                        fpath_line="fpath=(\"$completion_dir\" \$fpath)"
                        autoload_line="autoload -Uz compinit && compinit"
                        if ! grep -Fqx "$fpath_line" "$HOME/.zshrc" 2>/dev/null; then
                            printf '\n%s\n' "$fpath_line" >> "$HOME/.zshrc"
                        fi
                        if ! grep -Fqx "$autoload_line" "$HOME/.zshrc" 2>/dev/null; then
                            printf '%s\n' "$autoload_line" >> "$HOME/.zshrc"
                        fi
                        echo "Installed zsh completion: $completion_dst"
                        echo "Reload your shell with: source ~/.zshrc"
                        echo "Or open a new terminal session to activate just completions."
                        ;;
                    bash)
                        completion_dir="$HOME/.config/just"
                        completion_dst="$completion_dir/just_completion.bash"
                        source_line="[ -f \"$completion_dst\" ] && source \"$completion_dst\""
                        mkdir -p "$completion_dir"
                        just --completions bash > "$completion_dst"
                        if ! grep -Fqx "$source_line" "$HOME/.bashrc" 2>/dev/null; then
                            printf '\n%s\n' "$source_line" >> "$HOME/.bashrc"
                        fi
                        echo "Installed bash completion: $completion_dst"
                        echo "Reload your shell with: source ~/.bashrc"
                        echo "Or open a new terminal session to activate just completions."
                        ;;
                    *)
                        echo "Skipped shell completion install for unsupported shell: $shell_name"
                        ;;
                esac
            fi
            ;;
        dev)
            uv sync --all-extras
            uv run pre-commit install
            ;;
        "")
            uv sync
            ;;
        *)
            echo "ERROR: Unknown mode: {{mode}}"
            echo "Usage: just sync [prod|all|dev]"
            exit 1
            ;;
    esac

# Run lint checks via pre-commit.
# Usage:
#   just lint          # commit-aligned staged-files pre-commit
#   just lint --reuse  # duplicate/reuse/architecture diagnostics
#   just lint --full   # all-files pre-commit gate
#   just lint --repo   # full local repository gate
lint mode="": _check-completion
    #!/usr/bin/env bash
    set -euo pipefail

    source ./scripts/shared/hooks/quality_flag.sh

    print_lint_usage() {
        echo "Usage:"
        echo "  just lint          # commit-aligned staged-files pre-commit"
        echo "  just lint --reuse  # duplicate/reuse/architecture diagnostics"
        echo "  just lint --full   # all-files pre-commit gate"
        echo "  just lint --repo   # full local repository gate"
    }

    run_full_lint() {
        git_dir="$(quality_git_dir)"
        flag_file="$git_dir/.last_linted_commit"
        branch_name="$(quality_branch_name)"
        head_hash="$(quality_head_hash)"
        current_tree="$(quality_effective_tree working lint)"
        staged_archive_prd_transition=0
        if quality_has_staged_archive_prd_transition; then
            staged_archive_prd_transition=1
        fi

        if quality_skip_is_empty_or_only "check-test-flag" && [ "$staged_archive_prd_transition" -eq 0 ] && quality_flag_matches "$flag_file" "$branch_name" "$head_hash" "$current_tree"; then
            if ! quality_skip_contains "check-test-flag"; then
                bash ./scripts/shared/hooks/check_test_flag.sh
            fi
            echo "✅ just lint --full flag valid: $branch_name @ ${head_hash:0:8}"
            return 0
        fi

        if [ "$staged_archive_prd_transition" -eq 1 ]; then
            echo "🔍 staged archive PRD detected; running full lint checks."
        fi

        uv run pre-commit run --all-files --show-diff-on-failure

        if quality_skip_is_empty_or_only "check-test-flag"; then
            current_tree="$(quality_effective_tree working lint)"
            quality_write_flag "$flag_file" "$branch_name" "$head_hash" "$current_tree"
            echo "✅ just lint --full flag updated: $branch_name @ ${head_hash:0:8}"
        fi
    }

    run_reuse_lint() {
        reuse_status=0
        manual_reuse_hooks=(
            jscpd
            pylint-duplicate-code
        )
        regular_reuse_hooks=(
            check-architecture
            check-guidelines-consistency
            check-max-file-lines
        )

        for hook_id in "${manual_reuse_hooks[@]}"; do
            echo "🔍 Running reuse hook: $hook_id"
            if ! uv run pre-commit run "$hook_id" --hook-stage manual --all-files --show-diff-on-failure; then
                reuse_status=1
            fi
        done

        for hook_id in "${regular_reuse_hooks[@]}"; do
            echo "🔍 Running reuse hook: $hook_id"
            if ! uv run pre-commit run "$hook_id" --all-files --show-diff-on-failure; then
                reuse_status=1
            fi
        done

        return "$reuse_status"
    }

    case "{{mode}}" in
        "")
            uv run pre-commit run --show-diff-on-failure
            ;;
        --full)
            run_full_lint
            ;;
        --reuse)
            run_reuse_lint
            ;;
        --repo)
            SKIP=check-test-flag just lint --full
            just lint --reuse
            just test
            uv run mkdocs build --strict
            just lint --full
            ;;
        *)
            echo "ERROR: Unknown lint mode: {{mode}}"
            print_lint_usage
            exit 1
            ;;
    esac

# Serve MkDocs site locally with live reload (configurable port, default 8000)
docs-serve port="8000": _check-completion
    WATCHDOG_USE_POLLING=1 uv run mkdocs serve -a 127.0.0.1:{{port}}

# Remove cache files and build artifacts
clean:
    @echo "Cleaning cache files..."
    @rm -rf .ruff_cache
    @rm -rf __pycache__
    @find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
    @find . -type f -name "*.pyc" -delete 2>/dev/null || true
    @find . -type f -name "*.pyo" -delete 2>/dev/null || true
    @find . -type d -name "*.egg-info" -exec rm -rf {} + 2>/dev/null || true
    @echo "Clean complete!"

# Build a release zip (does NOT modify local workspace)
release:
    uv run python scripts/shared/release.py

# Run a diagnostic check.
# Usage:
#   just check net   # Verify terminal network environment for Claude access.
#   just check s3    # Verify S3 connectivity via zata-ops.
#
# The S3 check delegates to the standalone `zata-ops` CLI. Install it first:
#   cd /path/to/zata-ops && uv tool install --force .
check target:
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{target}}" in
        net)
            ./scripts/diagnostics/check_claude_code.sh
            ;;
        s3)
            if ! command -v zata-ops >/dev/null 2>&1; then
                echo "ERROR: zata-ops is not installed."
                echo "  cd /path/to/zata-ops && uv tool install --force ."
                exit 1
            fi
            zata-ops db check
            ;;
        *)
            echo "ERROR: Unknown check target: {{target}}"
            echo "Usage: just check [net|s3]"
            exit 1
            ;;
    esac

# Install or test macOS Shortcut notifications for Codex CLI.
# Usage:
#   just codex-notify install
#   just codex-notify install codex通知
#   just codex-notify test
codex-notify action="install" shortcut_name="codex通知":
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{action}}" in
        install)
            ./scripts/shared/codex/install_macos_notify.sh "{{shortcut_name}}"
            ;;
        test)
            CODEX_NOTIFY_VERBOSE=1 CODEX_NOTIFY_SHORTCUT_NAME="{{shortcut_name}}" ./scripts/shared/codex/notify_shortcut.sh '{"type":"agent-turn-complete","last-assistant-message":"Codex notify manual test"}'
            ;;
        *)
            echo "ERROR: Unknown action: {{action}}"
            echo "Usage: just codex-notify [install|test] [shortcut_name]"
            exit 1
            ;;
    esac

# Create a new Alembic migration script under alembic/versions/.
# The script enforces the YYYYMMDD_HHMMSS_<slug>.py naming convention defined
# in docs/ai-standards/alembic.md and refuses to run unless alembic has exactly
# one head. The caller still edits upgrade() / downgrade() by hand.
# Usage:
#   just new-migration <slug>           # ./alembic/versions/<timestamp>_<slug>.py
#   just new-migration <slug> <dir>     # custom alembic/versions directory
new-migration slug versions_dir="./alembic/versions":
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "{{slug}}" ]; then
        echo "ERROR: missing <slug>. Usage: just new-migration <slug> [versions_dir]"
        exit 2
    fi
    ./scripts/shared/alembic/new_migration.sh "{{slug}}" "{{versions_dir}}"

staged_changes:
    git diff --cached > staged_changes.diff

# Git worktree helper (implemented in scripts/shared/worktree/)
# Usage:
#   just worktree <branch>                            # create/enter worktree
#   just worktree <branch> --cmd trae                 # open in editor
#   just worktree <branch> enter_shell=false          # no shell
#   just worktree -o <branch> [--cmd trae]            # open existing worktree
#   just worktree -d <branch>                         # delete worktree
#   just worktree -m [<feature>] [base=main] [flags]  # merge worktree (current branch if omitted)
#   just worktree --doctor [branch]                   # doctor / cleanup-check
worktree arg1 arg2="" arg3="" arg4="" arg5="":
    #!/usr/bin/env bash
    set -euo pipefail

    # -o: open existing worktree
    if [ "{{arg1}}" = "-o" ]; then
        if [ -z "{{arg2}}" ]; then
            echo "ERROR: Usage: just worktree -o <branch_name> [--cmd editor]"
            exit 1
        fi
        open_cmd=(./scripts/shared/worktree/open.sh "{{arg2}}")
        for raw_arg in "{{arg3}}" "{{arg4}}" "{{arg5}}"; do
            if [ -n "$raw_arg" ]; then
                open_cmd+=("$raw_arg")
            fi
        done
        "${open_cmd[@]}"
        exit 0
    fi

    # -d: delete worktree
    if [ "{{arg1}}" = "-d" ]; then
        if [ -z "{{arg2}}" ]; then
            echo "ERROR: Usage: just worktree -d <branch_name>"
            exit 1
        fi
        ./scripts/shared/worktree/merge.sh "{{arg2}}" -d
        exit 0
    fi

    # -D: force delete worktree (bypass dirty/unmerged checks)
    if [ "{{arg1}}" = "-D" ]; then
        if [ -z "{{arg2}}" ]; then
            echo "ERROR: Usage: just worktree -D <branch_name>"
            exit 1
        fi
        ./scripts/shared/worktree/merge.sh "{{arg2}}" -D
        exit 0
    fi

    # -m: merge worktree
    if [ "{{arg1}}" = "-m" ]; then
        raw_arg2="{{arg2}}"
        declare -a merge_args=()

        if [ -z "$raw_arg2" ] || [[ "$raw_arg2" == -* ]]; then
            current_branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
            if [ -z "$current_branch" ]; then
                echo "ERROR: Could not determine current branch."
                echo "Usage: just worktree -m [<feature_branch>] [base_branch=main] [flags]"
                exit 1
            fi
            merge_args+=("$current_branch")
            if [ -n "$raw_arg2" ]; then
                merge_args+=("$raw_arg2")
            fi
            for raw_arg in "{{arg3}}" "{{arg4}}" "{{arg5}}"; do
                if [ -n "$raw_arg" ]; then
                    merge_args+=("$raw_arg")
                fi
            done
        else
            merge_args+=("$raw_arg2")
            for raw_arg in "{{arg3}}" "{{arg4}}" "{{arg5}}"; do
                if [ -n "$raw_arg" ]; then
                    merge_args+=("$raw_arg")
                fi
            done
        fi

        ./scripts/shared/worktree/merge.sh "${merge_args[@]}"
        exit 0
    fi

    # --doctor: cleanup-check
    if [ "{{arg1}}" = "--doctor" ]; then
        if [ -n "{{arg2}}" ]; then
            ./scripts/shared/worktree/merge.sh --doctor "{{arg2}}"
        else
            ./scripts/shared/worktree/merge.sh --doctor
        fi
        exit 0
    fi

    # Default: create/enter worktree
    branch_name="{{arg1}}"
    worktree_command=(./scripts/shared/worktree/create.sh "$branch_name")
    enter_shell_value="true"
    expect_code_command="false"
    expect_base_branch="false"
    expect_checkout_source="false"

    known_flag_pattern='--cmd|--cmd=*|--base|--base=*|--checkout|--checkout=*|--new|enter_shell=true|enter_shell=false'

    for raw_arg in "{{arg2}}" "{{arg3}}" "{{arg4}}" "{{arg5}}"; do
        if [ -z "$raw_arg" ]; then
            continue
        fi

        if [ "$expect_code_command" = "true" ]; then
            case "$raw_arg" in
                --cmd|--cmd=*|--base|--base=*|--checkout|--checkout=*|--new|enter_shell=true|enter_shell=false)
                    expect_code_command="false"
                    ;;
                *)
                    worktree_command+=("$raw_arg")
                    expect_code_command="false"
                    continue
                    ;;
            esac
        fi

        if [ "$expect_base_branch" = "true" ]; then
            case "$raw_arg" in
                --cmd|--cmd=*|--base|--base=*|--checkout|--checkout=*|--new|enter_shell=true|enter_shell=false)
                    expect_base_branch="false"
                    ;;
                *)
                    worktree_command+=("$raw_arg")
                    expect_base_branch="false"
                    continue
                    ;;
            esac
        fi

        if [ "$expect_checkout_source" = "true" ]; then
            case "$raw_arg" in
                --cmd|--cmd=*|--base|--base=*|--checkout|--checkout=*|--new|enter_shell=true|enter_shell=false)
                    expect_checkout_source="false"
                    ;;
                *)
                    worktree_command+=("$raw_arg")
                    expect_checkout_source="false"
                    continue
                    ;;
            esac
        fi

        case "$raw_arg" in
            --base)
                worktree_command+=(--base)
                expect_base_branch="true"
                ;;
            --base=*)
                worktree_command+=("$raw_arg")
                ;;
            --cmd)
                worktree_command+=(--cmd)
                expect_code_command="true"
                ;;
            --cmd=*)
                worktree_command+=("$raw_arg")
                ;;
            --checkout)
                worktree_command+=(--checkout)
                expect_checkout_source="true"
                ;;
            --checkout=*)
                worktree_command+=("$raw_arg")
                ;;
            --new)
                worktree_command+=(--new)
                ;;
            enter_shell=true)
                enter_shell_value="true"
                ;;
            enter_shell=false)
                enter_shell_value="false"
                ;;
            *)
                echo "ERROR: Invalid argument: $raw_arg"
                echo "Usage:"
                echo "  just worktree <branch> [--checkout [<src>] | --new] [--base branch] [--cmd [editor]] [enter_shell=false]"
                echo "  just worktree -o <branch> [--cmd editor]"
                echo "  just worktree -d <branch>"
                echo "  just worktree -m [<feature>] [base=main] [flags]"
                echo "  just worktree --doctor [branch]"
                exit 1
                ;;
        esac
    done

    "${worktree_command[@]}"

    if [ "$enter_shell_value" = "true" ]; then
        target_worktree_path="$(git worktree list --porcelain \
            | awk -v b="refs/heads/$branch_name" '
                /^worktree / { wt = substr($0, 10) }
                /^branch / && $2 == b { print wt; exit }
            ')"
        if [ -z "$target_worktree_path" ] || [ ! -d "$target_worktree_path" ]; then
            echo "ERROR: Could not locate worktree for $branch_name"
            exit 1
        fi
        echo "Entering worktree shell: $target_worktree_path"
        echo "Run 'exit' to return to previous shell."
        cd "$target_worktree_path"
        if [ -n "${TERM:-}" ] && [ "${TERM}" != "dumb" ]; then
            printf '\033]0;%s\007' "wt:$branch_name"
        fi

        user_shell="$(basename "${SHELL:-bash}")"
        if [ "$user_shell" = "zsh" ]; then
            zdotdir="$(mktemp -d)"
            printf '%s\n' \
                'if [ -f "$HOME/.zshrc" ]; then' \
                '    source "$HOME/.zshrc"' \
                'fi' \
                'if [ -n "${WORKTREE_BRANCH_NAME:-}" ]; then' \
                '    PS1="(wt:${WORKTREE_BRANCH_NAME}) ${PS1:-%n@%m:%~%# }"' \
                'fi' \
                'if [ -n "${WORKTREE_ZDOTDIR:-}" ] && [ -d "${WORKTREE_ZDOTDIR}" ]; then' \
                '    rm -rf "${WORKTREE_ZDOTDIR}" 2>/dev/null || true' \
                '    unset WORKTREE_ZDOTDIR' \
                'fi' \
                > "$zdotdir/.zshrc"
            exec env WORKTREE_BRANCH_NAME="$branch_name" WORKTREE_ZDOTDIR="$zdotdir" ZDOTDIR="$zdotdir" zsh -i
        else
            worktree_shell_rcfile="$(mktemp)"
            printf '%s\n' \
                'if [ -f "$HOME/.bashrc" ]; then' \
                '    source "$HOME/.bashrc"' \
                'fi' \
                'if [ -n "${WORKTREE_BRANCH_NAME:-}" ]; then' \
                '    PS1="(wt:${WORKTREE_BRANCH_NAME}) ${PS1:-\u@\h:\w\$ }"' \
                'fi' \
                'if [ -n "${WORKTREE_SHELL_RCFILE:-}" ] && [ -f "${WORKTREE_SHELL_RCFILE}" ]; then' \
                '    rm -f "${WORKTREE_SHELL_RCFILE}" 2>/dev/null || true' \
                '    unset WORKTREE_SHELL_RCFILE' \
                'fi' \
                > "$worktree_shell_rcfile"
            exec env WORKTREE_BRANCH_NAME="$branch_name" WORKTREE_SHELL_RCFILE="$worktree_shell_rcfile" bash --rcfile "$worktree_shell_rcfile" -i
        fi
    fi


# Create worktree from a PRD and start AI-assisted implementation.
# Automatically derives branch name from the PRD filename.
# When prompt is omitted, a default prompt is auto-generated from the PRD name.
# Usage:
#   just implement <prd-file> <claude|kimi> ["<prompt>"]
# Examples:
#   just implement tasks/pending/20260518-feature-x.md claude "Implement the feature per the PRD"
#   just implement tasks/pending/feature-x.md kimi "Implement this feature"
#   just implement tasks/pending/feature-x.md claude  # uses default prompt
implement prd_file ai_tool prompt="":
    #!/usr/bin/env bash
    set -euo pipefail

    prd_file="{{prd_file}}"
    ai_tool="{{ai_tool}}"
    prompt_text="{{prompt}}"
    repo_root="$(git rev-parse --show-toplevel)"

    # Validate PRD file exists
    if [ ! -f "$prd_file" ]; then
        echo "PRD file not found: $prd_file"
        echo "Usage: just implement <prd-file> <claude|kimi> \"<prompt>\""
        exit 1
    fi

    # Validate AI tool
    if [ "$ai_tool" != "claude" ] && [ "$ai_tool" != "kimi" ]; then
        echo "Unsupported AI tool: $ai_tool"
        echo "Supported tools: claude, kimi"
        echo "Usage: just implement <prd-file> <claude|kimi> \"<prompt>\""
        exit 1
    fi

    # Auto-generate default prompt if not provided
    if [ -z "$prompt_text" ]; then
        filename=$(basename "$prd_file")
        prd_name="${filename%.md}"
        # Strip date prefix for display
        if [[ "$prd_name" =~ ^[0-9]{8}-[0-9]{6}-(.+)$ ]]; then
            prd_display="${BASH_REMATCH[1]}"
        elif [[ "$prd_name" =~ ^[0-9]{8}-(.+)$ ]]; then
            prd_display="${BASH_REMATCH[1]}"
        else
            prd_display="$prd_name"
        fi
        evidence_dir="tasks/evidence/${prd_name}"
        executor_prompt_file="$repo_root/scripts/shared/just/executor_prompt.txt"
        prompt_text=$(cat "$executor_prompt_file")
        prompt_text="${prompt_text//<PRD_DISPLAY>/$prd_display}"
        prompt_text="${prompt_text//<EVIDENCE_DIR>/$evidence_dir}"
        prompt_text="${prompt_text//<PRD_BASENAME>/$prd_name}"
        echo "ℹ️  No prompt provided, using evidence-aware default prompt."
        echo ""
    fi

    # Extract branch name from PRD filename
    filename=$(basename "$prd_file")
    branch_name="${filename%.md}"
    # Strip date prefix: YYYYMMDD-HHMMSS- or YYYYMMDD-
    if [[ "$branch_name" =~ ^[0-9]{8}-[0-9]{6}-(.+)$ ]]; then
        branch_name="${BASH_REMATCH[1]}"
    elif [[ "$branch_name" =~ ^[0-9]{8}-(.+)$ ]]; then
        branch_name="${BASH_REMATCH[1]}"
    fi

    # Evidence directory (must match prompt and verifier expectations)
    evidence_dir="tasks/evidence/${prd_name}"

    echo "PRD: $prd_file"
    echo "Branch: $branch_name"
    echo "Tool: $ai_tool"
    echo "Evidence dir: $evidence_dir"
    echo "Prompt: $prompt_text"
    echo ""

    # Create worktree under tasks/ subdirectory
    ./scripts/shared/worktree/create.sh "$branch_name" --subdir tasks
    echo ""

    # Determine worktree path (must match scripts/shared/worktree/create.sh)
    repo_name="$(basename "$repo_root")"
    worktree_path="$(dirname "$repo_root")/${repo_name}-worktrees/tasks/$branch_name"

    # Copy PRD file into worktree preserving relative path
    prd_abs="$(cd "$(dirname "$prd_file")" && pwd)/$(basename "$prd_file")"
    prd_rel="$(python3 -c "import os.path; print(os.path.relpath('$prd_abs', '$repo_root'))")"
    prd_dest="$worktree_path/$prd_rel"
    mkdir -p "$(dirname "$prd_dest")"
    cp "$prd_abs" "$prd_dest"
    echo "PRD copied to worktree: $prd_rel"
    echo ""

    # Ensure evidence directory exists before executor runs
    mkdir -p "$worktree_path/$evidence_dir"

    # Run executor AI in worktree
    echo "Running executor ($ai_tool) in worktree..."
    cd "$worktree_path"
    ./scripts/shared/just/ai_run.sh "$ai_tool" "$prompt_text"

    echo ""

    # --- Verifier stage ---
    # Pick the opposite tool as the default verifier tool
    if [ "$ai_tool" = "claude" ]; then
        verifier_tool="kimi"
    else
        verifier_tool="claude"
    fi

    verifier_prompt_file="$repo_root/scripts/shared/just/verifier_prompt.txt"
    verifier_prompt=$(cat "$verifier_prompt_file")
    verifier_prompt="${verifier_prompt//<PRD_PATH>/$prd_rel}"
    verifier_prompt="${verifier_prompt//<EVIDENCE_DIR>/$evidence_dir}"
    verifier_prompt="${verifier_prompt//<PRD_BASENAME>/$prd_name}"

    run_verifier() {
        local tool="$1"
        echo "Running verifier ($tool)..."
        if ./scripts/shared/just/ai_run.sh "$tool" "$verifier_prompt"; then
            return 0
        fi
        return 1
    }

    verifier_ran=false

    if run_verifier "$verifier_tool"; then
        verifier_ran=true
    else
        echo "Verifier with $verifier_tool failed. Trying same tool as executor ($ai_tool)..."
        verifier_tool="$ai_tool"
        if run_verifier "$verifier_tool"; then
            verifier_ran=true
        fi
    fi

    if [ "$verifier_ran" != "true" ]; then
        echo ""
        echo "❌ ERROR: Both verifier tools are unavailable."
        echo "This usually indicates a quota, rate-limit, or API issue."
        echo "No PRD checkbox has been marked. Please resolve the issue and rerun 'just ai implement'."
        exit 1
    fi

    verifier_report="$worktree_path/$evidence_dir/${prd_name}.verifier-report.md"
    if [ ! -f "$verifier_report" ]; then
        echo ""
        echo "❌ ERROR: Verifier did not produce a report at $verifier_report"
        echo "Please review the output above and rerun 'just ai implement' if needed."
        exit 1
    fi

    verdict=$(head -n 1 "$verifier_report" | tr -d '[:space:]')
    if [ "$verdict" = "PASS" ]; then
        echo "✅ Verifier ($verifier_tool) passed."
    elif [ "$verdict" = "REJECT" ]; then
        echo ""
        echo "❌ Verifier ($verifier_tool) rejected the evidence."
        echo "Verifier report: $verifier_report"
        echo "Please review the report, fix the issues in the worktree, and rerun 'just ai implement'."
        exit 1
    else
        echo ""
        echo "⚠️  Verifier report has no clear PASS/REJECT verdict (first line: '$verdict')."
        echo "Verifier report: $verifier_report"
        echo "Please review manually."
        exit 1
    fi

    # --- Final evidence check ---
    echo ""
    echo "Running final evidence check..."
    cd "$repo_root"
    if ./scripts/shared/just/check_prd_evidence.sh "$prd_rel" "$worktree_path"; then
        echo "✅ Final evidence check passed."
    else
        echo "❌ Final evidence check failed."
        exit 1
    fi

    echo ""

    # Open worktree in VS Code (fallback to Code - Insiders)
    if command -v code &>/dev/null; then
        code "$worktree_path"
        echo "🚀 Opened worktree in VS Code: $worktree_path"
    elif command -v code-insiders &>/dev/null; then
        code-insiders "$worktree_path"
        echo "🚀 Opened worktree in VS Code Insiders: $worktree_path"
    fi

    echo "AI tool finished. Entering worktree shell..."
    echo "Run 'exit' to return to previous shell."
    echo ""

    cd "$worktree_path"
    if [ -n "${TERM:-}" ] && [ "${TERM}" != "dumb" ]; then
        printf '\033]0;%s\007' "wt:${branch_name}"
    fi
    exec "${SHELL:-bash}" -i


# AI-assisted commands.
# Usage:
#   just ai check <file_path>                 # review a file against project standards, then stay interactive
#   just ai check <file_path> kimi            # use kimi
#   just ai check <file_path> claude "prompt" # custom prompt (still interactive)
#   just ai fix                               # resolve git conflicts (rebase, merge, stash pop, cherry-pick, revert) with claude, then auto-continue
#   just ai fix kimi "custom prompt"          # resolve conflicts with kimi, then auto-continue
#   just ai commit                            # run `just test`, then commit with claude
#   just ai commit kimi "custom prompt"        # use kimi with a custom prompt
#   just ai push                              # run `just test`, commit, then push with claude
#   just ai push kimi "custom prompt"          # use kimi, then push
#   just ai implement <prd-file> [tool]       # implement a PRD (default: claude)
#   just ai tag <name>                        # write tag message and create annotated tag with claude
#   just ai tag <name> kimi "custom prompt"   # use kimi with a custom prompt
# Shortcuts: check, fix, commit, push, implement, tag — all delegate to scripts/shared/just/ai_run.sh
ai subcommand arg1="" arg2="" arg3="" :
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{subcommand}}" in
        check)
            just _ai_check "{{arg1}}" "{{arg2}}" "{{arg3}}"
            ;;
        fix)
            just _ai_fix "{{arg1}}" "{{arg2}}"
            ;;
        commit)
            just _ai_commit "{{arg1}}" "{{arg2}}"
            ;;
        push)
            just _ai_push "{{arg1}}" "{{arg2}}"
            ;;
        implement)
            just implement "{{arg1}}" "{{arg2}}" "{{arg3}}"
            ;;
        tag)
            just _ai_tag "{{arg1}}" "{{arg2}}" "{{arg3}}"
            ;;
        *)
            echo "Usage:"
            echo "  just ai check <file>  # review file against project standards, stay interactive"
            echo "  just ai fix           # resolve git conflicts (rebase, merge, stash pop, etc.)"
            echo "  just ai commit        # run just test, then commit"
            echo "  just ai push          # run just test, then commit and push"
            echo "  just ai implement     # implement a PRD"
            echo "  just ai tag <name>    # write tag message and create annotated tag"
            exit 1
            ;;
    esac

# Internal: review a single file against project standards, then stay interactive.
# Output is a structured report; the AI does NOT modify the file, and the
# REPL stays open so the caller can drill into findings or request targeted
# edits one at a time.
_ai_check file_path ai_tool="claude" prompt="":
    #!/usr/bin/env bash
    set -euo pipefail

    if [ -z "{{file_path}}" ]; then
        echo "Usage: just ai check <file_path> [claude|kimi] [prompt]"
        exit 1
    fi

    if [ ! -e "{{file_path}}" ]; then
        echo "ERROR: file not found: {{file_path}}"
        exit 1
    fi

    if [ -z "{{prompt}}" ]; then
        # Default prompt lives in a sibling file so this recipe body
        # stays short (just's recipe parser is indent-sensitive and
        # multi-line string literals are awkward inside a recipe).
        prompt_text="$(cat ./scripts/shared/just/ai_check_prompt.txt)"
        prompt_text="${prompt_text//<FILE_PATH>/{{file_path}}}"
    else
        prompt_text="{{prompt}}"
    fi

    ./scripts/shared/just/ai_run.sh "{{ai_tool}}" "$prompt_text" --interactive

# Internal: fix git rebase/merge conflicts with an AI tool.
_ai_fix ai_tool="claude" prompt="" :
    #!/usr/bin/env bash
    set -euo pipefail

    prompt_text="{{prompt}}"

    # Detect any unresolved conflicts (works for rebase, merge, cherry-pick, revert, stash pop)
    unmerged_files="$(git diff --name-only --diff-filter=U 2>/dev/null || true)"
    if [ -z "$unmerged_files" ]; then
        echo "No conflict files found — all clear."
        exit 0
    fi

    # Identify the conflict source for clearer messaging, prompt context, and
    # so we can run the correct `git * --continue` command afterwards.
    conflict_source="git conflict"
    git_dir="$(git rev-parse --git-dir)"
    rebase_in_progress="false"
    merge_in_progress="false"
    cherry_pick_in_progress="false"
    revert_in_progress="false"
    stash_in_progress="false"
    if [ -d "$git_dir/rebase-merge" ] || [ -d "$git_dir/rebase-apply" ]; then
        conflict_source="git rebase"
        rebase_in_progress="true"
    elif [ -f "$git_dir/MERGE_HEAD" ]; then
        conflict_source="git merge"
        merge_in_progress="true"
    elif [ -f "$git_dir/CHERRY_PICK_HEAD" ]; then
        conflict_source="git cherry-pick"
        cherry_pick_in_progress="true"
    elif [ -f "$git_dir/REVERT_HEAD" ]; then
        conflict_source="git revert"
        revert_in_progress="true"
    elif [ -n "$(git stash list)" ]; then
        conflict_source="git stash pop"
        stash_in_progress="true"
    fi

    echo "Conflicts from $conflict_source in:"
    printf '%s\n' "$unmerged_files"
    echo ""

    # Auto-generate default prompt
    if [ -z "$prompt_text" ]; then
        prompt_text="Resolve all git conflicts from $conflict_source. For each conflict file, read it, merge correctly preserving the intent of both sides where possible, remove all conflict markers, then git add the resolved file. Do NOT commit and do NOT run any 'git * --continue' command — only stage the resolved files. After all files are done, run 'just test' and ensure it passes."
    fi

    ./scripts/shared/just/ai_run.sh "{{ai_tool}}" "$prompt_text"

    # If the AI resolved everything, continue the interrupted git operation.
    # If conflicts remain, print the matching continue command so the user
    # knows exactly what to run after manual cleanup.
    remaining_unmerged="$(git diff --name-only --diff-filter=U 2>/dev/null || true)"
    if [ -n "$remaining_unmerged" ]; then
        echo ""
        echo "⚠️  Some conflicts are still unresolved:"
        printf '%s\n' "$remaining_unmerged"
        echo ""
        echo "Resolve them manually, then run the appropriate continue command:"
        [ "$rebase_in_progress" = "true" ]        && echo "  git rebase --continue"
        [ "$merge_in_progress" = "true" ]         && echo "  git merge --continue"
        [ "$cherry_pick_in_progress" = "true" ]   && echo "  git cherry-pick --continue"
        [ "$revert_in_progress" = "true" ]        && echo "  git revert --continue"
        [ "$stash_in_progress" = "true" ]         && echo "  git add . && git commit   (stash pop has no --continue)"
        exit 1
    fi

    if [ "$rebase_in_progress" = "true" ]; then
        echo ""
        echo "✅ All conflicts resolved. Continuing rebase..."
        GIT_EDITOR=true git rebase --continue
    elif [ "$merge_in_progress" = "true" ]; then
        echo ""
        echo "✅ All conflicts resolved. Continuing merge..."
        GIT_EDITOR=true git merge --continue
    elif [ "$cherry_pick_in_progress" = "true" ]; then
        echo ""
        echo "✅ All conflicts resolved. Continuing cherry-pick..."
        GIT_EDITOR=true git cherry-pick --continue
    elif [ "$revert_in_progress" = "true" ]; then
        echo ""
        echo "✅ All conflicts resolved. Continuing revert..."
        GIT_EDITOR=true git revert --continue
    elif [ "$stash_in_progress" = "true" ]; then
        echo ""
        echo "✅ All conflicts resolved from stash pop. Changes are staged; commit when ready."
    else
        echo ""
        echo "✅ All conflicts resolved and staged. Ready for you to review/continue."
    fi

# Internal: ask an AI tool to run `just test`, then commit current changes.
_ai_commit ai_tool="claude" prompt="" :
    #!/usr/bin/env bash
    set -euo pipefail

    prompt_text="{{prompt}}"

    # Fail fast if there is nothing to commit
    if [ -z "$(git status --porcelain)" ]; then
        echo "No changes to commit."
        exit 0
    fi

    # Auto-generate default prompt
    if [ -z "$prompt_text" ]; then
        prompt_text="First, run \`just test\` in the repository root to verify all tests pass. If tests fail, fix the underlying issues and re-run until \`just test\` is green. Once tests pass, review the current git changes (git status, git diff, and git diff --cached) and create a commit. Stage relevant files with git add, then write a clear commit message in English following conventional commit style (e.g. 'feat(scope): ...', 'fix(scope): ...', 'refactor(scope): ...'). Keep the subject line under 72 characters and use the body to explain the 'why' rather than the 'what'. Do NOT push. Do NOT amend existing commits. If pre-commit hooks fail, fix the underlying issues and create a new commit (never amend). Proceed autonomously without asking for confirmation at any step — commit directly once \`just test\` is green."
    fi

    ./scripts/shared/just/ai_run.sh "{{ai_tool}}" "$prompt_text"

# Internal: ask an AI tool to run `just test` and commit, then push the result.
_ai_push ai_tool="claude" prompt="" :
    #!/usr/bin/env bash
    set -euo pipefail

    prompt_text="{{prompt}}"

    # Fail fast if there is nothing to commit
    if [ -z "$(git status --porcelain)" ]; then
        echo "No changes to commit."
        exit 0
    fi

    # Auto-generate default prompt
    if [ -z "$prompt_text" ]; then
        prompt_text="First, run \`just test\` in the repository root to verify all tests pass. If tests fail, fix the underlying issues and re-run until \`just test\` is green. Once tests pass, review the current git changes (git status, git diff, and git diff --cached) and create a commit. Stage relevant files with git add, then write a clear commit message in English following conventional commit style (e.g. 'feat(scope): ...', 'fix(scope): ...', 'refactor(scope): ...'). Keep the subject line under 72 characters and use the body to explain the 'why' rather than the 'what'. Do NOT amend existing commits. If pre-commit hooks fail, fix the underlying issues and create a new commit (never amend). Proceed autonomously without asking for confirmation at any step — commit directly once \`just test\` is green. After you finish, the script will handle the push, so you do NOT need to push."
    fi

    ./scripts/shared/just/ai_run.sh "{{ai_tool}}" "$prompt_text"

    # AI finished - now handle push with safety checks and user confirmation.
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "🤖 AI finished. Preparing to push..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    current_branch="$(git rev-parse --abbrev-ref HEAD)"
    upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"

    if [ -z "$upstream" ]; then
        # No upstream - ask user to set up
        remote="$(git remote | head -1)"
        if [ -z "$remote" ]; then
            echo "ERROR: Branch '$current_branch' has no upstream and no git remote is configured."
            echo "Add a remote first, e.g.: git remote add origin <url>"
            exit 1
        fi

        echo "Branch '$current_branch' has no upstream."
        read -r -p "Push to '$remote/$current_branch' and set upstream? [Y/n] " confirm
        case "$confirm" in
            ""|y|Y|yes|YES)
                git push -u "$remote" "$current_branch"
                ;;
            *)
                echo "Push cancelled."
                exit 0
                ;;
        esac
    else
        # Has upstream - check ahead count
        ahead_count="$(git rev-list --count '@{u}'..HEAD 2>/dev/null || echo "0")"
        if [ "$ahead_count" -eq 0 ]; then
            echo "Nothing to push (branch '$current_branch' is up to date with $upstream)."
            exit 0
        fi

        echo "Branch '$current_branch' is $ahead_count commit(s) ahead of $upstream. Pushing..."
        git push
    fi

# Internal: ask an AI tool to write a release-note message and create an annotated git tag on the current commit.
_ai_tag tag_name ai_tool="claude" prompt="" :
    #!/usr/bin/env bash
    set -euo pipefail

    tag_name="{{tag_name}}"
    prompt_text="{{prompt}}"

    if [ -z "$tag_name" ]; then
        echo "Error: tag name is required."
        echo "Usage: just ai tag <name> [claude|kimi] [prompt]"
        exit 1
    fi

    # Tag is the only `ai` subcommand that strictly whitelists tools,
    # since wrong tool here would silently create a malformed tag.
    if [ "{{ai_tool}}" != "claude" ] && [ "{{ai_tool}}" != "kimi" ]; then
        echo "Unsupported AI tool: {{ai_tool}}"
        echo "Supported tools: claude, kimi"
        echo "Usage: just ai tag <name> [claude|kimi] [prompt]"
        exit 1
    fi

    if [ -z "$prompt_text" ]; then
        last_tag="$(git describe --tags --abbrev=0 2>/dev/null || true)"
        if [ -n "$last_tag" ]; then
            range_desc="commits since ${last_tag}"
            log_cmd="git log --oneline ${last_tag}..HEAD"
        else
            range_desc="all commits"
            log_cmd="git log --oneline"
        fi
        prompt_text="Summarize the ${range_desc} with \`${log_cmd}\` (and \`git diff --stat <ref>..HEAD\` if needed) and create an annotated git tag named '${tag_name}' on the current HEAD using \`git tag -a '${tag_name}' -m \"<release notes>\"\`. The tag message should be a scannable release note — short subject line, then a few bullet points describing user-visible changes. If the tag already exists locally, do NOT overwrite or delete it — stop and report the conflict. Do NOT push. Do NOT amend existing commits. Proceed autonomously without asking for confirmation — tag directly."
    fi

    echo "Tag: $tag_name"
    ./scripts/shared/just/ai_run.sh "{{ai_tool}}" "$prompt_text"

# Sync files from the upstream template repository.
# Compares local files against the template and lets you pick which to apply
# via an fzf TUI with per-entry diff preview.
# Usage:
#   just sync-template            # TUI: upstream-owned entries only
#   just sync-template --all      # TUI: all entries except config.toml project_skip_paths
#   just sync-template --list     # print upstream-owned entries, no TUI, no apply
#   just sync-template --list-all # print all entries, no TUI, no apply
#   just sync-template --dry-run  # run TUI but don't write anything
sync-template flags="":
    #!/usr/bin/env bash
    set -euo pipefail
    ./scripts/sync_template.sh {{flags}}

# Run tests after `just lint --full` (usage: just test [local|all|real])
#   just test        - Run local tests (no API keys needed; skip if code unchanged)
#   just test all    - Run all tests
#   just test real   - Run tests requiring API keys
@test type="local": _check-completion
    #!/usr/bin/env bash
    set -euo pipefail

    source ./scripts/shared/hooks/quality_flag.sh

    git_dir="$(quality_git_dir)"
    flag_file="$git_dir/.last_tested_commit"
    branch_name="$(quality_branch_name)"
    head_hash="$(quality_head_hash)"
    test_tree="$(quality_effective_tree working test)"

    if [ "{{type}}" = "local" ] && quality_flag_matches "$flag_file" "$branch_name" "$head_hash" "$test_tree"; then
        echo "✅ just test flag valid: $branch_name @ ${head_hash:0:8} (tree: ${test_tree:0:8}); skipping tests."
        exit 0
    fi

    echo "🔍 Running full lint checks..."
    if ! SKIP=check-test-flag just lint --full >/dev/null 2>&1; then
        echo "ERROR: Lint failed. Fix lint errors before running tests."
        echo "   Run: just lint --full"
        exit 1
    fi
    lint_tree_after_lint="$(quality_effective_tree working lint)"
    echo "✅ Lint passed. Proceeding to tests..."

    # Check Alembic migration heads if Alembic is installed
    if command -v alembic &>/dev/null; then
        alembic_heads="$(uv run alembic heads 2>/dev/null || true)"
        if [ -n "$alembic_heads" ]; then
            alembic_head_count="$(printf "%s\n" "$alembic_heads" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')"
            if [ "$alembic_head_count" -gt 1 ]; then
                echo "ERROR: Alembic migration graph must have exactly one head; found $alembic_head_count."
                printf "%s\n" "$alembic_heads"
                exit 1
            fi
        fi
    fi

    pytest_exit_code=0
    if [ "{{type}}" = "all" ]; then
        uv run pytest tests/ -v -m '' -n auto || pytest_exit_code=$?
    elif [ "{{type}}" = "real" ]; then
        uv run pytest tests/ -v -m 'real_api' -n auto || pytest_exit_code=$?
        if [ "$pytest_exit_code" -eq 5 ]; then
            echo "ℹ️  No real_api tests collected; treating as success."
            pytest_exit_code=0
        fi
    else
        # Local mode relies on pyproject.toml addopts to exclude slow/real_api
        # and to enable pytest-xdist parallel execution.
        uv run pytest tests/ -v || pytest_exit_code=$?
    fi

    if [ "$pytest_exit_code" -ne 0 ]; then
        exit "$pytest_exit_code"
    fi

    # Write flag after tests pass, binding branch, HEAD and effective tree.
    # Effective tree includes only files that may enter test/lint, excluding
    # docs, images and other unrelated types so .md edits don't trigger retest.
    branch_name="$(quality_branch_name)"
    head_hash="$(quality_head_hash)"
    test_tree="$(quality_effective_tree working test)"
    quality_write_flag "$git_dir/.last_tested_commit" "$branch_name" "$head_hash" "$test_tree"
    quality_write_flag "$git_dir/.last_linted_commit" "$branch_name" "$head_hash" "$lint_tree_after_lint"
    echo "✅ just test flag updated: $branch_name @ $head_hash"
    echo "✅ just lint --full flag updated: $branch_name @ $head_hash"


# Run Playwright e2e tests (requires: just e2e-install first)
# Usage:
#   just e2e            # all tests (excluding visual regression)
#   just e2e smoke      # smoke tests only
#   just e2e no-auth    # public-page tests (no login required)
#   just e2e report     # open HTML test report
e2e type="":
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{justfile_directory()}}/tests/playwright-e2e"
    case "{{type}}" in
        smoke)   npm run test:smoke ;;
        no-auth) npm run test:no-auth ;;
        report)  npm run report ;;
        "")      npm test ;;
        *)
            echo "ERROR: Unknown type: {{type}}"
            echo "Usage: just e2e [smoke|no-auth|report]"
            exit 1
            ;;
    esac

# Install e2e dependencies and Playwright browsers (run once before first just e2e)
e2e-install:
    cd "{{justfile_directory()}}/tests/playwright-e2e" && npm install && npx playwright install chromium

# Pack all gitignored .env* files into a password-protected encrypted zip.
# Output: ./<project_name>.zip  (one fixed file per project root)
# Password is prompted interactively at compression time; required again to extract.
export-env-encrypted:
    ./scripts/shared/secrets/export_env_encrypted.sh
